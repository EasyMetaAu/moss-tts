# ===== Port Configuration =====
NANO_PORT=6006
LOCAL_PORT=6007
REALTIME_PORT=6008

# ===== Model Weights Directory =====
# Absolute path to HuggingFace hub cache on the host
HF_HOME=/home/lukin/.cache/huggingface

# ===== Voices Directory =====
# Absolute path to voices directory on the host (WAV files)
VOICES_DIR=/home/lukin/code/moss-tts/voices

# ===== GPU Configuration =====
CUDA_VISIBLE_DEVICES=0

# ===== Text Segmentation =====
# Max characters per segment when splitting long texts
MAX_SEGMENT_CHARS=500

# ===== Service URLs (for MicroServices integration) =====
MOSS_SERVICE_URL=http://192.168.199.4:6006
MOSS_ENGINE=nano
