# ===== Port Configuration =====
NANO_PORT=6006
LOCAL_PORT=6007
REALTIME_PORT=6008
LOCAL_GGUF_PORT=6009

# ===== Model Weights Directory =====
# Path to directory containing downloaded model weights on the host
# Should contain: MOSS-TTS-Local-Transformer/ and MOSS-TTS-Realtime/ subdirs
MODEL_WEIGHTS_DIR=/home/lukin/models

# ===== HuggingFace Cache (for audio tokenizer etc.) =====
HF_HOME=/home/lukin/.cache/huggingface

# ===== Voices Directory =====
VOICES_DIR=/home/lukin/code/moss-tts/voices

# ===== GPU Configuration =====
CUDA_VISIBLE_DEVICES=0

# ===== Text Segmentation =====
# Max characters per segment when splitting long texts
MAX_SEGMENT_CHARS=500

# ===== Service URLs (for MicroServices integration) =====
MOSS_SERVICE_URL=http://192.168.199.4:18083
MOSS_ENGINE=nano

# GPU compute capability for llama.cpp local-gguf build (RTX 3090=86, 4090=89)
CUDA_ARCHS=86
